<AdicionarVendedorPage>:

    FloatLayout:
        canvas:
            Rectangle:
                size: self.size
                pos: self.pos
                source: "icones/bg1.png"
        Label:

            pos_hint: {"top":0.8, "right":0.9 }
            size_hint: 0.8, 0.2
            bold: True
            text:"Insira o [color=#00CFDB]ID de outro vendedor[/color] para adicioná-lo"
            markup: True

        LabelButton:
            canvas.before:
                Rectangle:
                    size: self.size
                    pos: self.pos
                    source: "icones/botao.png" if self.state == "normal" else "icones/botao_apertado.png"
            on_release: app.adicionar_vendedor(input_id_outrovendedor.text)
            text: "Adicionar Vendedor"
            pos_hint: {"top": 0.50, "right": 0.9}
            size_hint: 0.8, 0.2

        TextInput:
            pos_hint: {"top":0.6, "right":0.85 }
            size_hint: 0.7, 0.1
            id: input_id_outrovendedor

        Label:
            text: ""
            markup: True
            bold: True
            pos_hint: {"top":0.3, "right":0.9 }
            size_hint: 0.8, 0.1
            id: mensagem_outrovendedor


         # Botão voltar
        FloatLayout:
            pos_hint: {"top":0.12, "right":1 }
            size_hint: 1, 0.12
            canvas:
                Color:
                    rgb: utils.get_color_from_hex("#006D7E")
                Rectangle:
                    size: self.size
                    pos: self.pos
            ImageButton:
                pos_hint: {"top":0.9, "right":0.2 }
                size_hint: 0.2, 0.8
                source: "icones/voltar.png"
                on_release: app.mudar_tela("ajustespage")

